---
import '../styles/global.css';
import '@fontsource-variable/onest';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.webp" type="image/webp" />
		<title>MasterCred — Créditos en comercios de Junín</title>

		<!-- Facebook Meta Tags -->
        <meta property="og:url" content="https://master-cred.vercel.app/">
        <meta property="og:type" content="website">
        <meta property="og:title" content="MasterCred — Créditos en comercios de Junín">
        <meta property="og:description" content="MasterCred es una plataforma de créditos en comercios de Junín. Ofrecemos créditos simples y seguros para tus compras en comercios de Junín.">
        <meta property="og:image" content="https://www.opengraph.xyz/9479d5b3-a6f7-4551-8234-3d75865323bb">

<!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:domain" content="master-cred.vercel.app">
    <meta property="twitter:url" content="https://master-cred.vercel.app/">
    <meta name="twitter:title" content="MasterCred — Créditos en comercios de Junín">
    <meta name="twitter:description" content="MasterCred es una plataforma de créditos en comercios de Junín. Ofrecemos créditos simples y seguros para tus compras en comercios de Junín.">
    <meta name="twitter:image" content="https://www.opengraph.xyz/9479d5b3-a6f7-4551-8234-3d75865323bb">

		<meta name="robots" content="index, follow"/>
		<meta name="description" content="MasterCred es una plataforma de créditos en comercios de Junín. Ofrecemos créditos simples y seguros para tus compras en comercios de Junín."/>
		<meta name="keywords" content="MasterCred, créditos, comercios, Junín, prestamos, financiación, simple, seguro"/>
		<meta name="author" content="MasterCred" />
		<link rel="canonical" href="https://mastercred.com.ar" />
	</head>
	<body class="font-sans ">
		<Header />
		<main>
		    <slot />
	    </main>
		<Footer />
	</body>
	<script>
		import { initLenis } from '../scripts/lenis.js';
		initLenis();
	</script>
</html>



<style is:global>
	body {
        font-family: 'Onest Variable', system-ui, sans-serif;
	    *:focus-visible{
            outline: none;
            box-shadow: 0 0 0 1px #2563eb;
        }
}
</style>
