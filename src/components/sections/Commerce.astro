---
import { getCollection } from 'astro:content';
import CommerceItem from '../CommerceItem.astro';

const commerces = await getCollection('commerce');
const categories = [...new Set(commerces.map((c) => c.data.category))].sort();
---


<section class="py-10 md:py-20" id="comercios">
       <div class="container-section">
            <span class="text-sm text-label font-semibold mb-3">Comercios</span> 
            <h2 class="text-2xl md:text-3xl font-bold uppercase mt-2">
                Compra en <span class="text-blue-600">estos comercios</span>
            </h2>
            <p class="text-sm md:text-base text-gray-600 my-3">
                Locales adheridos donde podés pagar tus compras en cuotas.
            </p>

            <div class="flex flex-wrap gap-2 mt-6" id="commerce-filters">
                <button
                    data-filter="all"
                    class="filter-btn cursor-pointer active px-3 py-1.5 text-sm border rounded-md border-blue-500 bg-blue-500 text-white transition-all duration-200"
                >
                    Todos
                </button>
                {categories.map((category) => (
                    <button
                        data-filter={category}
                        class="filter-btn cursor-pointer px-3 py-1.5 text-sm border rounded-md border-black/20 text-black/70 hover:border-blue-500 hover:text-blue-500 transition-all duration-200"
                    >
                        {category}
                    </button>
                ))}
            </div>

            <ul class="grid grid-cols-3 md:grid-cols-5 mt-8" id="commerce-grid">
                {commerces.map((commerce: any) => (
                    <CommerceItem commerce={commerce} />
                ))}
            </ul>
       </div>
</section>

<script>
    const filters = document.getElementById('commerce-filters');
    const grid = document.getElementById('commerce-grid') as HTMLElement;
    const items = document.querySelectorAll<HTMLElement>('#commerce-grid li');

    let isAnimating = false;

    filters?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.filter-btn');
        if (!btn || btn.classList.contains('active') || isAnimating) return;

        const filter = btn.dataset.filter;
        isAnimating = true;

        filters.querySelectorAll('.filter-btn').forEach((b) => {
            b.classList.remove('active', 'bg-blue-500', 'text-white', 'border-blue-500');
            b.classList.add('border-black/20', 'text-black/70', 'hover:border-blue-500', 'hover:text-blue-500');
        });
        btn.classList.add('active', 'bg-blue-500', 'text-white', 'border-blue-500');
        btn.classList.remove('border-black/20', 'text-black/70', 'hover:border-blue-500', 'hover:text-blue-500');

        const lockedHeight = grid.offsetHeight;
        grid.style.minHeight = `${lockedHeight}px`;

        items.forEach((item) => {
            item.style.opacity = '0';
            item.style.transform = 'scale(0.95)';
        });

        setTimeout(() => {
            items.forEach((item) => {
                const show = filter === 'all' || item.dataset.category === filter;
                item.style.display = show ? '' : 'none';
            });

            requestAnimationFrame(() => {
                items.forEach((item) => {
                    if (item.style.display !== 'none') {
                        item.style.opacity = '1';
                        item.style.transform = 'scale(1)';
                    }
                });

                setTimeout(() => {
                    const gridTop = grid.getBoundingClientRect().top + window.scrollY;
                    const scrollBefore = window.scrollY;

                    grid.style.minHeight = '';
                    const heightDiff = lockedHeight - grid.offsetHeight;

                    if (heightDiff > 0 && scrollBefore > gridTop) {
                        window.scrollBy(0, -heightDiff);
                    }

                    isAnimating = false;
                }, 250);
            });
        }, 250);
    });
</script>