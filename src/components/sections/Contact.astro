---
import ContactForm from '../ContactForm.astro';
---


<section id="contact" class="bg-gray-50 overflow-hidden relative py-10 md:py-20">

    <div class="container-section">
        
        <span class="text-sm text-label font-semibold mb-3"> Contacto</span>
        <h2 class="text-2xl md:text-3xl md:max-w-xl text-balance font-bold uppercase mt-2">
            Empezá tu <span class="text-blue-600">financiación</span> en MasterCred
        </h2>
        <p class="text-sm md:text-base text-gray-600 max-w-sm md:max-w-xl mt-6">
            Completá el formulario y nos pondremos en contacto para empezar tu financiación.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
            <ContactForm />
        </div>

    </div>
    <div class="absolute bottom-7 inset-x-0 justify-center items-center opacity-5 translate-y-1/2 pointer-events-none flex">
        <span class="text-4xl md:text-[8rem] font-black uppercase">Contacto</span>
    </div>
</section>