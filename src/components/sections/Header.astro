---
import { Image } from 'astro:assets';
import logo from '../../assets/images/logo.webp';
---

<header class="fixed z-50 w-full mx-auto p-2.5 border-b border-black/20 backdrop-blur-xl bg-white/50 ">

   <div class="max-w-5xl mx-auto flex items-center justify-between">
            <a href="/" class="flex items-center  gap-x-2 hover:scale-105 transition-all duration-300">
                <Image src={logo} alt="MasterCred" class="size-4" />
                <span class="text-md font-medium uppercase hidden md:block">MasterCred</span>
            </a>
        

        <nav>
            <ul class="flex items-center text-sm text-black/70 gap-x-6">
                <li>
                    <a href="/" class=" hover:text-blue-500 transition-all duration-300">Funcionamiento</a>
                </li>
                <li>
                    <a href="/" class=" hover:text-blue-500 transition-all duration-300">Comercios</a>
                </li>
                <li>
                    <a href="/" class=" hover:text-blue-500 transition-all duration-300">Beneficios</a>
                </li>
                <li>
                    <a href="/" class=" hover:text-blue-500 transition-all duration-300">FAQ</a>
                </li>
            </ul>
        </nav>
        <a href="/" class="text-sm px-3 py-1.5 border border-blue-500 font-medium hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-500/30 hover:text-white transition-all duration-200">
            Solicitar préstamo
        </a>
    </div>
</header>   