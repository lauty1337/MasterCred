---
import { Image } from 'astro:assets';
import logo from '../../assets/images/logo.webp';

const navLinks = [
	{ href: '#function', label: 'Funcionamiento' },
	{ href: '#commerce', label: 'Comercios' },
	{ href: '#contact', label: 'Contacto' },
];
---

<header id="header" class="invisible fixed z-50 w-full mx-auto p-2.5 border-b border-black/20 backdrop-blur-xl bg-white/70">
	<div class="container-section flex items-center justify-between">
		<a href="#hero" data-header-logo class="flex items-center gap-x-2">
			<Image src={logo} alt="Logo de MasterCred" title="Logo de MasterCred" class="size-8 md:size-6  " />
			<span class="text-md font-medium text-gray-600 uppercase hidden md:block">MasterCred</span>
		</a>

		<nav class="hidden md:block" aria-label="Navegación principal">
			<ul class="flex items-center text-sm text-gray-600 gap-x-6">
				{navLinks.map((link) => (
					<li data-header-item>
						<a href={link.href} class="hover:text-blue-600 transition-all duration-300">{link.label}</a>
					</li>
				))}
			</ul>
		</nav>

		<div class="flex items-center gap-1.5 sm:gap-2 shrink-0">
			<a
				href="#contact"
				data-header-cta
				class="inline-flex text-xs sm:text-sm px-2.5 sm:px-3 py-1.5 border border-blue-600 font-medium text-blue-600 hover:bg-blue-600 hover:shadow-lg hover:shadow-blue-600/30 hover:text-white transition-colors duration-200 whitespace-nowrap"
			>
				Solicitar crédito
			</a>
			<button
				type="button"
				class="menu-toggle md:hidden inline-flex items-center justify-center rounded-md p-2 text-gray-700 hover:bg-black/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600"
				aria-expanded="false"
				aria-controls="panel-menu-movil"
				data-menu-toggle
			>
				<span class="sr-only" data-menu-toggle-label>Abrir menú</span>
				<span class="relative block h-5 w-6" aria-hidden="true">
					<span class="menu-bar menu-bar--1 absolute left-0 top-0.5 h-0.5 w-6 rounded bg-current transition-all duration-300"></span>
					<span class="menu-bar menu-bar--2 absolute left-0 top-1/2 h-0.5 w-6 -translate-y-1/2 rounded bg-current transition-all duration-300"></span>
					<span class="menu-bar menu-bar--3 absolute left-0 bottom-0.5 h-0.5 w-6 rounded bg-current transition-all duration-300"></span>
				</span>
			</button>
		</div>
	</div>
</header>
<!-- Panel FUERA del header para que no herede backdrop-blur ni stacking context -->
<div
	id="panel-menu-movil"
	class="group fixed inset-0 z-60 md:hidden opacity-0 pointer-events-none transition-opacity duration-300 [&.is-open]:opacity-100 [&.is-open]:pointer-events-auto"
	aria-hidden="true"
	data-mobile-menu
>
	<div class="absolute inset-0 bg-black/40 backdrop-blur-md" data-menu-backdrop></div>

	<div class="absolute right-0 top-0 h-full w-4/5 max-w-xs bg-white shadow-2xl flex flex-col p-8 pt-16 translate-x-full transition-transform duration-300 ease-out group-[.is-open]:translate-x-0">
		<nav aria-label="Navegación móvil">
			<ul class="flex flex-col gap-6 text-lg text-gray-800">
				{navLinks.map((link) => (
					<li>
						<a href={link.href} class="block py-1 hover:text-blue-600 transition-colors duration-200" data-menu-link>
							{link.label}
						</a>
					</li>
				))}
			</ul>
		</nav>
		<a
			href="#contact"
			class="mt-auto text-center text-sm px-4 py-2.5 bg-blue-600 text-white font-medium hover:bg-blue-500 transition-colors duration-200 rounded-sm"
			data-menu-link
		>
			Solicitar crédito
		</a>
	</div>
</div>

<style>
	.menu-toggle[aria-expanded='true'] .menu-bar--1 {
		transform: translateY(8px) rotate(45deg);
	}
	.menu-toggle[aria-expanded='true'] .menu-bar--2 {
		opacity: 0;
	}
	.menu-toggle[aria-expanded='true'] .menu-bar--3 {
		transform: translateY(-8px) rotate(-45deg);
	}
</style>

<script>
	import '../../scripts/animations/header.js';
</script>
