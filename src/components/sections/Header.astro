---
import { Image } from 'astro:assets';
import logo from '../../assets/images/logo.webp';

---

<header id="header" class="invisible fixed z-50 w-full mx-auto p-2.5 border-b border-black/20 backdrop-blur-xl bg-white/70">

   <div class="container-section flex items-center justify-between">

            <a href="#hero" data-header-logo class="flex items-center gap-x-2 hover:scale-105 transition-[scale] duration-300">
                <Image src={logo} alt="Logo de MasterCred" class="size-4" />
                <span class="text-md font-medium text-gray-600 uppercase hidden md:block">MasterCred</span>
            </a>
        <nav aria-label="Navegación principal">
            <ul class="flex items-center text-sm text-gray-600 gap-x-6">
                <li data-header-item>
                    <a href="#function" class="hover:text-blue-500 transition-all duration-300">Funcionamiento</a>
                </li>
                <li data-header-item>
                    <a href="#commerce" class="hover:text-blue-500 transition-all duration-300">Comercios</a>
                </li>
                <li data-header-item>
                    <a href="#benefits" class="hover:text-blue-500 transition-all duration-300">Beneficios</a>
                </li>
                <li data-header-item>
                    <a href="#faq" class="hover:text-blue-500 transition-all duration-300">FAQ</a>
                </li>
            </ul>
        </nav>
        <a href="#contact" data-header-cta class="text-sm px-3 py-1.5 border border-blue-500 font-medium hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-500/30 hover:text-white transition-colors duration-200">
            Solicitar préstamo
        </a>    
    </div>
</header> 

<script>
    import '../../scripts/animations/header.js';
</script>