---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
    commerce: CollectionEntry<'commerce'>;
}

const { commerce } = Astro.props;
const { data } = commerce;
---

<li class="relative group overflow-hidden border border-black/20 transition-[opacity,transform] duration-250 ease-out" data-category={data.category}>
    <Image src={data.image} alt={data.title} class="size-40 xs:size-48 md:size-58 object-cover transition-all duration-300 group-hover:scale-105"  />
    <div class="absolute text-center inset-0 bg-black/50 md:bg-black/70 opacity-100 md:opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3">
        <h3 class="text-white font-semibold">{data.title}</h3>
        <p class="text-white/80 text-sm">{data.address}</p>
        <p class="text-white/60 text-xs">{data.category}</p>
    </div>
</li>
